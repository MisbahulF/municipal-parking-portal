# ──────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL) CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=pvp_user
DB_PASSWORD=pvp_password
DB_NAME=pvp_db

# ──────────────────────────────────────────────────────────────────────────────
# API GATEWAY CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
API_GATEWAY_PORT=8080
CORS_ORIGIN=http://localhost:3000

# Service Discovery URLs (for API Gateway within Docker Network)
VIOLATION_SERVICE_URL=http://violation-service:8081
BILLING_SERVICE_URL=http://billing-service:8082
PAYMENT_SERVICE_URL=http://payment-service:8083

# ──────────────────────────────────────────────────────────────────────────────
# MICROSERVICES INDIVIDUAL PORTS
# ──────────────────────────────────────────────────────────────────────────────
VIOLATION_SERVICE_PORT=8081
BILLING_SERVICE_PORT=8082
PAYMENT_SERVICE_PORT=8083

# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
